# Zoho CRM (optional — skip to run without CRM checking)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_API_REGION=com            # com, eu, in, com.au, jp, ca

# SMTP Email
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=                     # defaults to SMTP_USER if blank
RECIPIENTS=ebeulens@acutech-consulting.com,nistre@acutech-consulting.com

# News search
LOOKBACK_HOURS=24              # 24 for daily, 168 for weekly
GDELT_MAX_RECORDS=250
